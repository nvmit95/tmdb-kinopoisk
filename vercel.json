{
  "rewrites": [
    {
      "source": "/api/tmdb/:path*",
      "destination": "https://api.themoviedb.org/3/:path*"
    },
    {
      "source": "/api/tmdb-image/:path*",
      "destination": "https://image.tmdb.org/:path*"
    },
    {
      "source": "/api/tmdb-static/:path*",
      "destination": "https://www.themoviedb.org/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
